# Supabase configuration
# Copy this file to .env and fill in your own values.
# Both values are found in your Supabase project at: Settings → API

# Your project URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# The public anon key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Note: the delete-account Edge Function uses SUPABASE_SERVICE_ROLE_KEY, which
# is automatically available to all Edge Functions as a built-in secret. You do
# NOT need to set it here. Deploy the function with:
#
#   supabase functions deploy delete-account
# ──────────────────────────────────────────────────────────────────────────────
